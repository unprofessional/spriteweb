---
import '../styles/global.css';

const {
  title = 'SPRITEbot',
  description = 'Tabletop RPG campaigns, right inside Discord.',
} = Astro.props;

const basePath = import.meta.env.BASE_URL;
const pageTitle = title === 'SPRITEbot' ? title : `${title} | SPRITEbot`;
const navItems = [
  { href: `${basePath}`, label: 'Home' },
  { href: `${basePath}pricing/`, label: 'Pricing' },
  { href: `${basePath}guide/`, label: 'Guide' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href={`${basePath}assets/sprite-mark.svg`} />
    <title>{pageTitle}</title>
  </head>
  <body>
    <div class="site-shell">
      <header class="site-header">
        <a class="brand" href={basePath} aria-label="SPRITEbot home">
          <img src={`${basePath}assets/sprite-mark.svg`} alt="" width="36" height="36" />
          <span>SPRITEbot</span>
        </a>
        <nav class="site-nav" aria-label="Main navigation">
          {
            navItems.map((item) => (
              <a href={item.href} class={Astro.url.pathname === new URL(item.href, Astro.site).pathname ? 'active' : ''}>
                {item.label}
              </a>
            ))
          }
        </nav>
      </header>
      <main>
        <slot />
      </main>
      <footer class="site-footer">
        <p>Built for Discord tables that like their campaign tools close at hand.</p>
        <a href={`${basePath}legal/`}>Terms & Privacy</a>
      </footer>
    </div>
  </body>
</html>
