---
import Base from '../layouts/Base.astro';

const inviteUrl =
  'https://discord.com/oauth2/authorize?client_id=1398118069771173978&permissions=294745402368&scope=bot%20applications.commands';
const supportUrl = 'https://discord.gg/eXktxzKxze';
const basePath = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;

const features = [
  {
    title: 'Campaign Management',
    copy: 'Create games, define custom stat templates, and publish campaigns when players are ready to join.',
  },
  {
    title: 'Character Sheets',
    copy: 'Guide players through character creation with custom fields and public or private visibility.',
  },
  {
    title: 'In-Character Roleplay',
    copy: 'Use webhook-powered `/ic` and `/ooc` posts that support long messages, edits, and tidy character voices.',
  },
  {
    title: 'Inventory Tracking',
    copy: 'Manage per-character items with campaign-specific fields, quantities, and clean sheet summaries.',
  },
  {
    title: 'Dice Rolling',
    copy: 'Roll cryptographic dice from `1d2` through `15d999`, right where the table is already talking.',
  },
  {
    title: 'Thread Bumping',
    copy: 'Keep play-by-post channels alive with scheduled bumps for registered campaign threads.',
  },
  {
    title: 'Voice Transcription',
    copy: 'Let GMs capture a session in a voice channel and post a raw timestamped transcript when it ends.',
  },
];
---

<Base
  title="SPRITEbot"
  description="Run lightweight tabletop RPG campaigns with character sheets, dice, inventory, and in-character Discord posting."
>
  <section class="hero">
    <div class="hero-content">
      <p class="eyebrow">Discord-native campaign tools</p>
      <h1>Tabletop RPG campaigns, right inside Discord.</h1>
      <p class="hero-copy">
        SPRITEbot helps GMs and players manage games, characters, roleplay posts, inventory, dice,
        voice transcripts, and thread upkeep without dragging the table into another app.
      </p>
      <div class="hero-actions" aria-label="Primary actions">
        <a class="button primary" href={inviteUrl}><svg class="button-icon" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg"><path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.095 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.095 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"/></svg>Add to Discord</a>
        <a class="button secondary" href={`${basePath}pricing/`}>View Pricing</a>
        <a class="button secondary" href={supportUrl}><svg class="button-icon" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg"><path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.095 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.095 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"/></svg>Support Server</a>
      </div>
    </div>
    <div class="hero-panel" aria-label="SPRITEbot feature preview">
      <div class="bot-card">
        <img src={`${basePath}assets/sprite-mark.svg`} alt="" width="72" height="72" />
        <div>
          <strong>SPRITEbot</strong>
          <span>/ic Mira checks the warded door...</span>
        </div>
      </div>
      <div class="command-preview">
        <span class="prompt">/roll</span>
        <span>2d20+4</span>
        <strong>18, 11</strong>
      </div>
      <div class="stat-grid" aria-hidden="true">
        <span>STR 2</span>
        <span>DEX 4</span>
        <span>WIT 3</span>
        <span>CHA 1</span>
      </div>
    </div>
  </section>

  <section class="feature-section" aria-labelledby="features-heading">
    <div class="section-heading">
      <p class="eyebrow">What it handles</p>
      <h2 id="features-heading">A campaign kit that lives where play happens.</h2>
    </div>
    <div class="feature-grid">
      {
        features.map((feature) => (
          <article class="feature-card">
            <h3>{feature.title}</h3>
            <p>{feature.copy}</p>
          </article>
        ))
      }
    </div>
  </section>
</Base>
