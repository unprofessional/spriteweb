---
import Base from '../layouts/Base.astro';

const basePath = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
---

<Base title="Legal" description="SPRITEbot terms and privacy information.">
  <section class="page-hero legal-hero">
    <p class="eyebrow">Legal</p>
    <h1>Terms & Privacy</h1>
    <p>
      Legal policies governing your use of SPRITEbot and how we handle your data.
    </p>
  </section>

  <div class="legal-content">
    <section class="policy-section">
      <h2>Terms of Service</h2>
      <p>
        Rules and conditions for using SPRITEbot, including acceptable use, subscriptions,
        service availability, and liability.
      </p>
      <p>
        <a class="button secondary" href={`${basePath}terms/`}>Read Terms of Service</a>
      </p>
    </section>

    <section class="policy-section">
      <h2>Privacy Policy</h2>
      <p>
        What data SPRITEbot collects, how it is used, your rights, and how to request deletion.
      </p>
      <p>
        <a class="button secondary" href={`${basePath}privacy/`}>Read Privacy Policy</a>
      </p>
    </section>
  </div>
</Base>
